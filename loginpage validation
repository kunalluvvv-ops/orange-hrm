package com.orangehrm.tests;
import com.orangehrm.config.Config;
import com.orangehrm.pages.DashboardPage;
import com.orangehrm.pages.LoginPage;
import org.testng.Assert;
import org.testng.annotations.Test;
public class LoginTest extends BaseTest {
    @Test(description = "Verify successful login flow with default valid credentials")
    public void testSuccessfulLogin() {
        LoginPage loginPage = new LoginPage(driver);
        DashboardPage dashboardPage = new DashboardPage(driver);
        loginPage.navigateToLogin();
        loginPage.login(Config.getDefaultUsername(), Config.getDefaultPassword());
        Assert.assertTrue(dashboardPage.isDashboardHeaderVisible(), "Dashboard header is not visible");
        Assert.assertTrue(dashboardPage.getTitle().contains("Dashboard"), "Title is incorrect");
        Assert.assertFalse(dashboardPage.getLoggedInUsername().trim().isEmpty(), "Logged-in user header is empty");
    }
    @Test(description = "Verify error messages display when submitting invalid credentials")
    public void testInvalidLogin() {
        LoginPage loginPage = new LoginPage(driver);
        loginPage.navigateToLogin();
        loginPage.login("InvalidUser", "invalidPassword");
        Assert.assertEquals(loginPage.getErrorMessageText(), "Invalid credentials");
    }
}
