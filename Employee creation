
import com.orangehrm.config.Config;
import com.orangehrm.pages.DashboardPage;
import com.orangehrm.pages.LoginPage;
import com.orangehrm.pages.PIMPage;
import org.testng.Assert;
import org.testng.annotations.Test;
public class PIMTest extends BaseTest {
    @Test(description = "Verify that a new employee can be successfully added to the system")
    public void testAddNewEmployee() {
        LoginPage loginPage = new LoginPage(driver);
        DashboardPage dashboardPage = new DashboardPage(driver);
        PIMPage pimPage = new PIMPage(driver);
        loginPage.navigateToLogin();
        loginPage.login(Config.getDefaultUsername(), Config.getDefaultPassword());
        dashboardPage.navigateToPim();
        String empId = pimPage.addEmployee("John", "Doe", "Smith");
        Assert.assertFalse(empId.isEmpty(), "Employee ID was not generated");
        Assert.assertTrue(pimPage.isSuccessToastVisible(), "Confirmation banner is not visible");
        Assert.assertTrue(pimPage.getSuccessToastText().contains("Successfully Saved"), "Unexpected toast alert content");
    }
}
